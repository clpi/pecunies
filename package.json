{
  "name": "pecunies",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:wasm": "node scripts/build-wasm.mjs",
    "sync:posts": "node scripts/sync-posts.mjs",
    "test": "node --test",
    "test:sanity": "node scripts/sanity-check.mjs",
    "preview": "vite preview",
    "deploy:pages": "npm run build && npx wrangler pages deploy dist --project-name pecunies-chaos-portfolio",
    "deploy:edge": "npx wrangler deploy --config workers/edge/wrangler.jsonc",
    "deploy:booking-email": "npx wrangler deploy --config workers/booking-email/wrangler.jsonc",
    "deploy:mcp": "npx wrangler deploy --config workers/mcp/wrangler.jsonc",
    "deploy:cloudflare": "npm run deploy:pages && npm run deploy:booking-email && npm run deploy:edge && npm run deploy:mcp",
    "deploy": "npm run deploy:cloudflare",
    "publish": "npm run deploy:cloudflare"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@cloudflare/ai-utils": "^1.0.1",
    "@cloudflare/workers-types": "^4.20260430.1",
    "dompurify": "^3.4.1",
    "marked": "^18.0.2"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-universal": "^2.0.0"
  }
}
